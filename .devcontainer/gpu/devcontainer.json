{
  "name": "Research-Project-Dev-Env (GPU)",
  "shutdownAction": "none",

  // --- [Template] docker-compose で共通設定 + GPU override ---
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.override.yml"],
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  // --- [Template] devcontainer 固有の共通設定 ---
  "overrideCommand": false,
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  // Note: claude-code-config volume は docker-compose.yml で定義（named volume でプレフィックス抑制）
  // Note (2026-04-03): docker-outside-of-docker feature は docker-compose + NVIDIA
  // entrypoint で command: [] 強制セットのバグあり。Dockerfile で Docker CLI を直接
  // インストールして回避中。See: https://github.com/devcontainers/features/issues/954
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-toolsai.jupyter"]
    }
  },

  // --- [Template] GPU 固有のライフサイクル ---
  "initializeCommand": "bash .devcontainer/../scripts/check-nvidia-symlinks.sh 2>/dev/null || true",
  "postStartCommand": "bash .devcontainer/post-start.sh; nvidia-smi > /dev/null 2>&1 && echo '[GPU] Access OK' || echo '[GPU] WARNING: GPU access lost. Container restart required.' >&2; bash scripts/qa/start-bot.sh 2>&1 || true",

  // --- [Project] プロジェクト固有の追加セットアップをここに追記 ---
  "postCreateCommand": "bash .devcontainer/post-create.sh ${localWorkspaceFolderBasename}"
}
